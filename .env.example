# Recap Studio — example environment variables.
# Copy to .env.local and fill ONLY the ones you need.
# Recap Studio runs fully offline by default; every key below is opt-in.

# --- Email (optional, default mode = "disabled") -------------------------
# Used only if recap-studio.config.ts -> emailMode != "disabled" AND the
# user confirms at runtime. Never auto-send.
RESEND_API_KEY=
DEFAULT_EMAIL_FROM=
DEFAULT_EMAIL_TO=

# --- Vercel deploy (optional, default mode = "disabled") -----------------
# The CLI uses its own auth. These are only consumed by the deploy script
# if present, and only after explicit confirmation.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Optional research providers (used only when researchIntensity !=
#     "fast" AND the relevant key is set; never required). -----------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=

# --- Runtime knobs (optional) --------------------------------------------
# RECAP_STUDIO_HOME overrides where artifacts and source cache live.
RECAP_STUDIO_HOME=
# RECAP_STUDIO_FIXTURE_ONLY=1 forces fixture mode regardless of config.
RECAP_STUDIO_FIXTURE_ONLY=1
