{
  "name": "@recap-studio/cli",
  "version": "0.3.0",
  "description": "The `recap` CLI — turn a RecapPageContent JSON into a self-contained dark-mode HTML page, or score it. Works in any editor/terminal, no Claude required.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "recap": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/*.test.ts",
    "lint": "echo 'cli: no lint configured yet'"
  },
  "dependencies": {
    "@recap-studio/content-pipeline": "workspace:*",
    "@recap-studio/html-renderer": "workspace:*",
    "@recap-studio/validation": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
