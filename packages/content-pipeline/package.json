{
  "name": "@recap-studio/content-pipeline",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./load-config": {
      "types": "./dist/load-config.d.ts",
      "import": "./dist/load-config.js"
    },
    "./load": {
      "types": "./dist/load.d.ts",
      "import": "./dist/load.js"
    }
  },
  "files": ["dist", "fixtures"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/*.test.ts",
    "lint": "echo 'pipeline: no lint configured yet (uses repo prettier)'"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
